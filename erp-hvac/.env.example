# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # service_role key — JAMAIS exposé côté client
SUPABASE_ANON_KEY=eyJ...             # anon/public key — utilisé dans le frontend

# Dashboard Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# Dashboard Supabase → Project Settings → API → JWT Settings → JWT Secret
JWT_SECRET=your_jwt_secret_here

# ── Email — Resend ─────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxx
RESEND_FROM=noreply@votredomaine.ae

# ── WhatsApp — Twilio ──────────────────────────────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Staging uniquement ────────────────────────────────────────────────────────
# Projet Supabase dédié au staging (séparé de la prod)
STAGING_SUPABASE_URL=https://yyyy.supabase.co
STAGING_SUPABASE_SERVICE_ROLE_KEY=eyJ...
STAGING_SUPABASE_ANON_KEY=eyJ...
STAGING_DATABASE_URL=postgresql://postgres:[password]@db.yyyy.supabase.co:5432/postgres
STAGING_JWT_SECRET=your_staging_jwt_secret_here
