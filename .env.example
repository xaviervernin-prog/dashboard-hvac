# Copier vers .env.production ou .env.test et remplir les valeurs
ENVIRONMENT=production
DEBUG=false

# Supabase (obtenir depuis le projet Supabase > Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...votre-anon-key...

# Clé secrète JWT (générer avec : openssl rand -hex 32)
SECRET_KEY=changez-moi-en-production
